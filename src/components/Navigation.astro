---
const pathname = Astro.url.pathname;
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : base + "/";
---

<nav class="main-nav">
  <div class="container nav-container">
      <a href="/" class="nav-brand" style="text-decoration: none; display: inline-flex; align-items: center; color: #00d4ff;">
          <div style="color: #ff9738; font-size: 4rem; margin-right: 15px; line-height: 1;">
              <!--&gt;_-->
              <i class="fa-solid fa-terminal"></i>
          </div>
          <div style="display: flex; flex-direction: column; width: fit-content;font-family: 'Ubuntu',serif">
              <div style="display: flex; justify-content: space-between; font-size: 2.7rem; font-weight: 800; letter-spacing: 0; line-height: 1;">
                  <span>B</span><span>G</span><span>M</span>
              </div>
              <div style="font-size: 1rem; font-weight: lighter; line-height: 1; letter-spacing: 1px;">
                  SOLUTIONS
              </div>
          </div>
      </a>
    <button class="mobile-menu-btn" aria-label="Abrir menú">
      <i class="fas fa-bars"></i>
    </button>

    <ul class="nav-links">
      <li>
        <a href="/#" class={pathname === basePath ? "active" : ""}
          >Inicio</a>
      </li>
      <li>
        <a
          href="/consultoria"
          class={pathname.includes("/consultoria") ? "active" : ""}
          >Consultoría</a
        >
      </li>
      <li>
        <a
          href="/desarrollo-software"
          class={pathname.includes("/desarrollo-software") ? "active" : ""}
          >Desarrollo a Medida</a
        >
      </li>
      <li>
        <a
          href="/ciencia-datos"
          class={pathname.includes("/ciencia-datos") ? "active" : ""}
          >Ciencia de Datos</a
        >
      </li>
    </ul>
  </div>
</nav>

<script is:inline>
  function setupMobileMenu() {
    const mobileBtn = document.querySelector(".mobile-menu-btn");
    const navLinks = document.querySelector(".nav-links");

    if (mobileBtn && navLinks) {
      mobileBtn.addEventListener("click", () => {
        navLinks.classList.toggle("active");
        const icon = mobileBtn.querySelector("i");
        if (icon) {
          icon.classList.toggle("fa-bars");
          icon.classList.toggle("fa-times");
        }
      });
    }
  }

  // Ejecutar en la carga inicial
  setupMobileMenu();

  // Ejecutar después de cada navegación con View Transitions
  document.addEventListener("astro:page-load", setupMobileMenu);
</script>